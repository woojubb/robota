# Ignore test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Ignore build output
dist/
build/
coverage/

# Ignore node modules
node_modules/

# Ignore config files
*.config.js
*.config.ts
*.config.mjs
vitest.config.ts
tsup.config.ts

# Ignore documentation
docs/
*.md

# Build outputs
out/

# Documentation
apps/docs/

# Examples
apps/examples/
packages/*/examples/

# Other
.next/
.turbo/
.vscode/
.idea/

# Scripts directory (utility scripts, not package code)
scripts/

# Jest setup and config files
**/jest.setup.js
**/jest.config.js

# ESLint config files
**/.eslintrc.cjs

# Vitest setup files
vitest.setup.ts
**/vitest.setup.ts