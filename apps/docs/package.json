{
  "name": "robota-docs",
  "version": "1.0.25",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3020",
    "build": "next build",
    "postbuild": "pagefind --site out",
    "start": "next start --port 3020",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "deploy": "pnpm build && wrangler pages deploy out --project-name robota-docs --branch main"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "mermaid": "^11.4.1",
    "next": "15.4.1",
    "next-intl": "^4.12.0",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.26.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1",
    "typescript": "^5"
  }
}
