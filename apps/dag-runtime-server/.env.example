# ── Server ──
# DAG_PORT=3011
# CORS_ORIGINS=http://localhost:3000
# DAG_REQUEST_BODY_LIMIT=15mb
# DAG_DEFAULT_TIMEOUT_MS=30000
# DAG_STORAGE_ROOT=.dag-storage
# ASSET_STORAGE_ROOT=.local-assets

# ── Node API Keys (required per node type) ──

# OpenAI — required for llm-text-openai node
OPENAI_API_KEY=

# Gemini — required for gemini-image-compose / gemini-image-edit nodes
GEMINI_API_KEY=
# DAG_GEMINI_IMAGE_DEFAULT_MODEL=
# DAG_GEMINI_IMAGE_ALLOWED_MODELS=

# Seedance — required for seedance-video node
BYTEDANCE_API_KEY=
BYTEDANCE_BASE_URL=
# ARK_API_KEY=
# DAG_SEEDANCE_DEFAULT_MODEL=
# DAG_SEEDANCE_ALLOWED_MODELS=
