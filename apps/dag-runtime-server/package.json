{
    "name": "@robota-sdk/dag-runtime-server",
    "version": "3.0.0",
    "description": "DAG Runtime Server - ComfyUI-compatible Prompt API execution server",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "build": "tsup",
        "test": "vitest run --passWithNoTests",
        "lint": "eslint src --ext .ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@robota-sdk/dag-api": "workspace:*",
        "@robota-sdk/dag-core": "workspace:*",
        "@robota-sdk/dag-node-gemini-image-edit": "workspace:*",
        "@robota-sdk/dag-node-image-loader": "workspace:*",
        "@robota-sdk/dag-node-image-source": "workspace:*",
        "@robota-sdk/dag-node-input": "workspace:*",
        "@robota-sdk/dag-node-llm-text-openai": "workspace:*",
        "@robota-sdk/dag-node-ok-emitter": "workspace:*",
        "@robota-sdk/dag-node-seedance-video": "workspace:*",
        "@robota-sdk/dag-node-text-output": "workspace:*",
        "@robota-sdk/dag-node-text-template": "workspace:*",
        "@robota-sdk/dag-node-transform": "workspace:*",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "multer": "^2.1.1",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.10.0",
        "@types/ws": "^8.18.1",
        "tsup": "^8.5.0",
        "tsx": "^4.6.0",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    }
}
