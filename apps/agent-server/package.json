{
  "name": "@robota-sdk/agent-server",
  "version": "3.0.1-beta.6",
  "description": "Agent Server - AI provider proxy and Playground WebSocket server",
  "private": true,
  "keywords": [
    "robota",
    "ai",
    "api",
    "express",
    "firebase",
    "functions",
    "proxy",
    "remote",
    "streaming"
  ],
  "author": "Robota Team",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup",
    "build:functions": "tsc -p tsconfig.functions.json",
    "serve:functions": "npm run build:functions && firebase emulators:start --only functions",
    "deploy:functions": "npm run build:functions && firebase deploy --only functions",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist lib"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-provider-anthropic": "workspace:*",
    "@robota-sdk/agent-provider-bytedance": "workspace:*",
    "@robota-sdk/agent-provider-google": "workspace:*",
    "@robota-sdk/agent-provider-openai": "workspace:*",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-winston": "^4.2.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.8.0",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "tsup": "^8.5.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "lib"
  ]
}
