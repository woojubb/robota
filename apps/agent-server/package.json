{
  "name": "@robota-sdk/agent-server",
  "version": "3.0.1-beta.34",
  "description": "Agent Server - AI provider proxy and Playground WebSocket server",
  "private": true,
  "keywords": [
    "robota",
    "ai",
    "api",
    "express",
    "firebase",
    "functions",
    "proxy",
    "remote",
    "streaming"
  ],
  "author": "Robota Team",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup",
    "build:functions": "tsc -p tsconfig.functions.json",
    "serve:functions": "npm run build:functions && firebase emulators:start --only functions",
    "deploy:functions": "npm run build:functions && firebase deploy --only functions",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist lib"
  },
  "dependencies": {
    "@robota-sdk/agent-command": "workspace:*",
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-framework": "workspace:*",
    "@robota-sdk/agent-interface-transport": "workspace:*",
    "@robota-sdk/agent-playground": "workspace:*",
    "@robota-sdk/agent-provider": "workspace:*",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "files": [
    "dist",
    "lib"
  ]
}
