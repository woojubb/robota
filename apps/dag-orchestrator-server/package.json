{
    "name": "@robota-sdk/dag-orchestrator-server",
    "version": "3.0.0",
    "description": "DAG Orchestrator Server - orchestration gateway with cost/auth/retry policies over DAG runtime or ComfyUI backends",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "build": "tsup",
        "test": "vitest run --passWithNoTests",
        "lint": "eslint src --ext .ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@robota-sdk/dag-core": "workspace:*",
        "@robota-sdk/dag-orchestrator": "workspace:*",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "tsup": "^8.5.0",
        "tsx": "^4.6.0",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    }
}
