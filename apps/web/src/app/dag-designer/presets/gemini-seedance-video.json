{
  "metadata": {
    "templateId": "gemini-seedance-video",
    "name": "Gemini Compose to Seedance Video",
    "description": "Create a compose DAG with two image-source nodes feeding gemini-image-compose, then generate a video from the composed image using seedance-video."
  },
  "definition": {
    "dagId": "dag-template-gemini-seedance-video",
    "version": 1,
    "status": "draft",
    "nodes": [
      {
        "nodeId": "image_source_a_1",
        "nodeType": "image-source",
        "position": {
          "x": 120,
          "y": 80
        },
        "dependsOn": [],
        "inputs": [],
        "outputs": [
          {
            "key": "image",
            "label": "Image",
            "order": 0,
            "type": "binary",
            "required": true,
            "binaryKind": "image",
            "mimeTypes": [
              "image/png"
            ]
          }
        ],
        "config": {}
      },
      {
        "nodeId": "image_source_b_1",
        "nodeType": "image-source",
        "position": {
          "x": 120,
          "y": 260
        },
        "dependsOn": [],
        "inputs": [],
        "outputs": [
          {
            "key": "image",
            "label": "Image",
            "order": 0,
            "type": "binary",
            "required": true,
            "binaryKind": "image",
            "mimeTypes": [
              "image/png"
            ]
          }
        ],
        "config": {}
      },
      {
        "nodeId": "compose_prompt_1",
        "nodeType": "input",
        "position": {
          "x": 120,
          "y": 440
        },
        "dependsOn": [],
        "inputs": [],
        "outputs": [
          {
            "key": "text",
            "label": "Text",
            "order": 0,
            "type": "string",
            "required": true
          }
        ],
        "config": {
          "text": "두 이미지를 합성해서 커플 사진을 만들어줘. 여자는 원본에 최대한 가까운 얼굴을 유지하고, 남자 사진은 너무 늙어보이지 않게 30대의 얼굴로 만들어줘."
        }
      },
      {
        "nodeId": "video_prompt_1",
        "nodeType": "input",
        "position": {
          "x": 620,
          "y": 500
        },
        "dependsOn": [],
        "inputs": [],
        "outputs": [
          {
            "key": "text",
            "label": "Text",
            "order": 0,
            "type": "string",
            "required": true
          }
        ],
        "config": {
          "text": "환하게 웃는 얼굴을 보여줘. 대사가 필요하면 한국어로 해줘."
        }
      },
      {
        "nodeId": "gemini_image_compose_1",
        "nodeType": "gemini-image-compose",
        "position": {
          "x": 620,
          "y": 220
        },
        "dependsOn": [
          "image_source_a_1",
          "image_source_b_1",
          "compose_prompt_1"
        ],
        "inputs": [
          {
            "key": "images",
            "label": "Images",
            "order": 0,
            "type": "binary",
            "required": true,
            "isList": true,
            "minItems": 2,
            "binaryKind": "image",
            "mimeTypes": [
              "image/png",
              "image/jpeg",
              "image/webp"
            ]
          },
          {
            "key": "prompt",
            "label": "Prompt",
            "order": 1,
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "key": "image",
            "label": "Image",
            "order": 0,
            "type": "binary",
            "required": true,
            "binaryKind": "image",
            "mimeTypes": [
              "image/png",
              "image/jpeg",
              "image/webp"
            ]
          }
        ],
        "config": {
          "model": "gemini-3.1-flash-image-preview"
        }
      },
      {
        "nodeId": "seedance_video_1",
        "nodeType": "seedance-video",
        "position": {
          "x": 1080,
          "y": 360
        },
        "dependsOn": [
          "gemini_image_compose_1",
          "video_prompt_1"
        ],
        "inputs": [
          {
            "key": "prompt",
            "label": "Prompt",
            "order": 0,
            "type": "string",
            "required": true
          },
          {
            "key": "images",
            "label": "Images",
            "order": 1,
            "type": "binary",
            "required": false,
            "isList": true,
            "minItems": 1,
            "binaryKind": "image",
            "mimeTypes": [
              "image/png",
              "image/jpeg",
              "image/webp"
            ]
          }
        ],
        "outputs": [
          {
            "key": "video",
            "label": "Video",
            "order": 0,
            "type": "binary",
            "required": true,
            "binaryKind": "video",
            "mimeTypes": [
              "video/mp4"
            ]
          }
        ],
        "config": {
          "model": "seedance-1-5-pro-251215",
          "pollIntervalMs": 3000,
          "pollTimeoutMs": 180000
        }
      }
    ],
    "edges": [
      {
        "from": "image_source_a_1",
        "to": "gemini_image_compose_1",
        "bindings": [
          {
            "outputKey": "image",
            "inputKey": "images[0]"
          }
        ]
      },
      {
        "from": "image_source_b_1",
        "to": "gemini_image_compose_1",
        "bindings": [
          {
            "outputKey": "image",
            "inputKey": "images[1]"
          }
        ]
      },
      {
        "from": "compose_prompt_1",
        "to": "gemini_image_compose_1",
        "bindings": [
          {
            "outputKey": "text",
            "inputKey": "prompt"
          }
        ]
      },
      {
        "from": "gemini_image_compose_1",
        "to": "seedance_video_1",
        "bindings": [
          {
            "outputKey": "image",
            "inputKey": "images[0]"
          }
        ]
      },
      {
        "from": "video_prompt_1",
        "to": "seedance_video_1",
        "bindings": [
          {
            "outputKey": "text",
            "inputKey": "prompt"
          }
        ]
      }
    ],
    "costPolicy": {
      "runCreditLimit": 100,
      "costPolicyVersion": 2
    }
  }
}