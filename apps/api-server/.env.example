# Robota API Server Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# DAG Local Development Server
# Used by: pnpm --filter @robota-sdk/api-server dag:dev
DAG_DEV_PORT=3011
# Local asset storage root for DAG asset API
ASSET_STORAGE_ROOT=.local-assets

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://robota.io,https://playground.robota.io

# Rate Limiting
RATE_LIMIT_MAX=100

# AI Provider API Keys
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI
GOOGLE_API_KEY=your_google_api_key_here

# DAG LLM Node Runtime Policy
# Default provider used when node config.provider is not set
DAG_LLM_DEFAULT_PROVIDER=openai
# Global default model for default provider (used when provider-specific default is not set)
DAG_LLM_DEFAULT_MODEL=gpt-4o-mini
# Provider-specific default models (used when node config.model is not set)
DAG_LLM_DEFAULT_OPENAI_MODEL=gpt-4o-mini
DAG_LLM_DEFAULT_ANTHROPIC_MODEL=
DAG_LLM_DEFAULT_GOOGLE_MODEL=
# Optional allowlists; when configured, node model must match one of the listed values
DAG_LLM_ALLOWED_OPENAI_MODELS=gpt-4o-mini,gpt-4.1-mini
DAG_LLM_ALLOWED_ANTHROPIC_MODELS=
DAG_LLM_ALLOWED_GOOGLE_MODELS=

# Firebase Configuration (for authentication)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Logging
LOG_LEVEL=debug

# Security
JWT_SECRET=your_jwt_secret_here
API_VERSION=v1
