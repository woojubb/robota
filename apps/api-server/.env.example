# Robota API Server (DAG) environment template

# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
BYTEDANCE_API_KEY=your_bytedance_api_key_here

# ByteDance ModelArk endpoint
BYTEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# DAG Seedance runtime policy
DAG_SEEDANCE_DEFAULT_MODEL=seedance-1-5-pro-251215
DAG_SEEDANCE_ALLOWED_MODELS=seedance-1-5-pro-251215

# DAG LLM runtime policy
DAG_LLM_DEFAULT_PROVIDER=openai
DAG_LLM_DEFAULT_MODEL=gpt-4o-mini

# DAG Gemini image runtime policy
DAG_GEMINI_IMAGE_DEFAULT_MODEL=gemini-2.5-flash-image
DAG_GEMINI_IMAGE_ALLOWED_MODELS=gemini-2.5-flash-image

# DAG server limits
DAG_REQUEST_BODY_LIMIT=20mb
DAG_DEFAULT_TIMEOUT_MS=600000
