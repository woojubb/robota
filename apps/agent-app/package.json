{
  "name": "@robota-sdk/agent-app",
  "version": "3.0.0-beta.79",
  "private": true,
  "description": "agent-app — an Electron desktop application that drives a robota session over a loopback WS sidecar; the desktop GUI surface, rendering the shared GUI presentation core @robota-sdk/agent-transport-gui (GUI-005)",
  "author": "Robota",
  "homepage": "https://github.com/woojubb/robota",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.build.json",
    "build": "pnpm build:renderer && pnpm build:electron",
    "start": "electron dist/electron/main.js",
    "bundle:runtime": "node scripts/bundle-runtime.mjs",
    "dist:app": "pnpm build && pnpm bundle:runtime && electron-builder --publish never",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "xvfb-run -a node e2e/run-e2e.mjs",
    "test:e2e:bundled": "node e2e/bundled-runtime-e2e.mjs",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@robota-sdk/agent-transport-gui": "workspace:*",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@robota-sdk/agent-transport-ws": "workspace:*",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.2.6"
  }
}
