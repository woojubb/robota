{
  "name": "robota-web",
  "version": "0.1.0",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "private": true,
  "description": "Minimal Next.js host for Robota Agent Playground (/playground)",
  "scripts": {
    "dev": "next dev --port 7071",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "analyze": "ANALYZE=true npm run build",
    "lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:^",
    "@robota-sdk/agent-playground": "workspace:^",
    "@robota-sdk/agent-transport-gui": "workspace:^",
    "@robota-sdk/agent-transport-webrtc-web": "workspace:*",
    "next": "^15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "buffer": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "process": "^0.11.10",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
