---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = await getCollection('blog', ({ data }) => data.lang === 'en');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Robota Blog" description="Coding agents, AI, and development" lang="en" translationUrl="/ko/">
  <h1>blog</h1>
  <p class="intro">Coding agents, AI, and development</p>

  <ul class="post-list">
    {sortedPosts.map((post) => {
      const slug = post.id.replace('en/', '');
      const date = new Date(post.data.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
      return (
        <li>
          <a href={`/${slug}/`}>
            <time>{date}</time>
            <span class="post-title">{post.data.title}</span>
            {post.data.subtitle && (
              <span class="post-subtitle">{post.data.subtitle}</span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</Base>

<style>
  h1 {
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-dim);
    margin-bottom: 48px;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }

  .post-list li:last-child {
    border-bottom: none;
  }

  .post-list a {
    display: block;
    padding: 24px 0;
    text-decoration: none;
    transition: background 0.2s;
  }

  .post-list a:hover {
    color: inherit;
  }

  .post-list a:hover .post-title {
    color: var(--green);
  }

  time {
    display: block;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .post-title {
    display: block;
    font-family: var(--mono);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    transition: color 0.2s;
  }

  .post-subtitle {
    display: block;
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-top: 4px;
  }
</style>
