---
import Base from '../layouts/Base.astro';

const postFiles = import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.values(postFiles) as any[];
const sortedPosts = posts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Base title="Robota blog" description="코딩 에이전트, AI, 개발 이야기">
  <h1>blog</h1>
  <p class="intro">코딩 에이전트, AI, 개발 이야기</p>

  <ul class="post-list">
    {sortedPosts.map((post) => {
      const date = new Date(post.frontmatter.date).toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
      return (
        <li>
          <a href={post.url}>
            <time>{date}</time>
            <span class="post-title">{post.frontmatter.title}</span>
            {post.frontmatter.subtitle && (
              <span class="post-subtitle">{post.frontmatter.subtitle}</span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</Base>

<style>
  h1 {
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-dim);
    margin-bottom: 48px;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }

  .post-list li:last-child {
    border-bottom: none;
  }

  .post-list a {
    display: block;
    padding: 24px 0;
    text-decoration: none;
    transition: background 0.2s;
  }

  .post-list a:hover {
    color: inherit;
  }

  .post-list a:hover .post-title {
    color: var(--green);
  }

  time {
    display: block;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .post-title {
    display: block;
    font-family: var(--mono);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    transition: color 0.2s;
  }

  .post-subtitle {
    display: block;
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-top: 4px;
  }
</style>
