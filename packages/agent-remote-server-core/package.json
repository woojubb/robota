{
  "name": "@robota-sdk/agent-remote-server-core",
  "version": "3.0.0",
  "description": "[DEPRECATED] Use @robota-sdk/agent-transport-http instead. Will be removed after agent-server migration.",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "remote",
    "api",
    "openapi",
    "typescript",
    "sdk"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-remote": "workspace:*",
    "express": "^4.18.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
