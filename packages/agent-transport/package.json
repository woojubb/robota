{
  "name": "@robota-sdk/agent-transport",
  "version": "3.0.0-beta.73",
  "description": "Consolidated transport package for Robota SDK — headless, HTTP, WebSocket, and MCP adapters",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "source": "./src/index.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    },
    "./headless": {
      "types": "./dist/node/headless/index.d.ts",
      "source": "./src/headless/index.ts",
      "node": {
        "import": "./dist/node/headless/index.js",
        "require": "./dist/node/headless/index.cjs"
      },
      "default": {
        "import": "./dist/node/headless/index.js",
        "require": "./dist/node/headless/index.cjs"
      }
    },
    "./http": {
      "types": "./dist/node/http/index.d.ts",
      "source": "./src/http/index.ts",
      "node": {
        "import": "./dist/node/http/index.js",
        "require": "./dist/node/http/index.cjs"
      },
      "default": {
        "import": "./dist/node/http/index.js",
        "require": "./dist/node/http/index.cjs"
      }
    },
    "./ws": {
      "types": "./dist/node/ws/index.d.ts",
      "source": "./src/ws/index.ts",
      "node": {
        "import": "./dist/node/ws/index.js",
        "require": "./dist/node/ws/index.cjs"
      },
      "default": {
        "import": "./dist/node/ws/index.js",
        "require": "./dist/node/ws/index.cjs"
      }
    },
    "./mcp": {
      "types": "./dist/node/mcp/index.d.ts",
      "source": "./src/mcp/index.ts",
      "node": {
        "import": "./dist/node/mcp/index.js",
        "require": "./dist/node/mcp/index.cjs"
      },
      "default": {
        "import": "./dist/node/mcp/index.js",
        "require": "./dist/node/mcp/index.cjs"
      }
    },
    "./tui": {
      "types": "./dist/node/tui/index.d.ts",
      "source": "./src/tui/index.ts",
      "node": {
        "import": "./dist/node/tui/index.js",
        "require": "./dist/node/tui/index.cjs"
      },
      "default": {
        "import": "./dist/node/tui/index.js",
        "require": "./dist/node/tui/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-framework": "workspace:*",
    "@robota-sdk/agent-interface-transport": "workspace:*",
    "@robota-sdk/agent-interface-tui": "workspace:*",
    "chalk": "^5.6.2",
    "hono": "^4.12.25",
    "ink": "^7.0.5",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^9.1.6",
    "marked-terminal": "^7.3.0",
    "react": "19.2.4",
    "string-width": "^8.2.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@robota-sdk/agent-command": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4.0.0",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
