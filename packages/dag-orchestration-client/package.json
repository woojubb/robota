{
  "name": "@robota-sdk/dag-orchestration-client",
  "version": "3.0.0-beta.60",
  "private": true,
  "description": "Thin client contracts for Robota DAG orchestration APIs",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "dag",
    "orchestration",
    "client",
    "typescript"
  ],
  "author": "Robota SDK Team",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/dag-core": "workspace:*",
    "@robota-sdk/dag-cost": "workspace:*",
    "@robota-sdk/dag-builder": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsdown": "^0.22.2",
    "typescript": "^5.3.3",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
