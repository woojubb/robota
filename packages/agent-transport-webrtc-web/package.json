{
  "name": "@robota-sdk/agent-transport-webrtc-web",
  "version": "3.0.0-beta.79",
  "description": "Browser WebRTC transport peer for a robota session (REMOTE-009 Stage D) — native RTCPeerConnection answerer + fail-closed pairing gate + RemoteClient page + useRtcSession, over the shared GUI core. The browser mirror of the node-side agent-transport-webrtc host transport.",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@robota-sdk/agent-remote-pairing": "workspace:*",
    "@robota-sdk/agent-transport-gui": "workspace:*",
    "@robota-sdk/agent-transport-protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "private": true
}
