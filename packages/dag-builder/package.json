{
  "name": "@robota-sdk/dag-builder",
  "version": "0.1.0-beta.0",
  "private": true,
  "description": "Declarative pipeline-to-DAG-definition builder and validator",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "dag",
    "builder",
    "pipeline"
  ],
  "author": "Robota SDK Team",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/dag-core": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.22.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
