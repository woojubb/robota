{
  "name": "@robota-sdk/dag-node-gemini-image-edit",
  "version": "3.0.0-beta.47",
  "description": "DAG gemini-image-edit node for Robota",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/node/index.js"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "author": "Robota SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/dag-core": "workspace:*",
    "@robota-sdk/dag-node": "workspace:*",
    "@robota-sdk/agent-provider-google": "workspace:*",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
