{
  "name": "@robota-sdk/agent-playground",
  "version": "3.0.0-beta.79",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "description": "Deployable Playground UI package (React implementation) for Robota SDK",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/browser/index.js"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    },
    "./client": {
      "types": "./dist/browser/client.d.ts",
      "import": "./dist/browser/client.js",
      "default": "./dist/browser/client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.21",
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-collapsible": "^1.1.18",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-navigation-menu": "^1.2.20",
    "@radix-ui/react-progress": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-switch": "^1.3.5",
    "@radix-ui/react-tabs": "^1.1.19",
    "@robota-sdk/agent-core": "workspace:^",
    "@robota-sdk/agent-remote-client": "workspace:*",
    "@robota-sdk/agent-tools": "workspace:^",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^0.525.0",
    "monaco-editor": "^0.56.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jsdom": "^25.0.1",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.14",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
