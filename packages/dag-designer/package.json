{
  "name": "@robota-sdk/dag-designer",
  "version": "3.0.0",
  "description": "Web designer layer for Robota DAG",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/node/index.js"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "dag",
    "designer",
    "web",
    "typescript",
    "sdk"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/dag-api": "workspace:*",
    "@robota-sdk/dag-core": "workspace:*",
    "@xyflow/react": "^12.8.2"
  },
  "devDependencies": {
    "@robota-sdk/dag-node-image-loader": "workspace:*",
    "@robota-sdk/dag-node-image-source": "workspace:*",
    "@robota-sdk/dag-node-input": "workspace:*",
    "@robota-sdk/dag-node-llm-text-openai": "workspace:*",
    "@robota-sdk/dag-node-ok-emitter": "workspace:*",
    "@robota-sdk/dag-node-text-output": "workspace:*",
    "@robota-sdk/dag-node-transform": "workspace:*",
    "eslint": "^8.56.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
