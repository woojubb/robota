{
  "name": "@robota-sdk/agent-provider-gemini",
  "version": "3.0.0-beta.79",
  "description": "Google Gemini provider implementation for Robota SDK",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "source": "./src/index.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    },
    "./google": {
      "types": "./dist/node/google/index.d.ts",
      "source": "./src/google.ts",
      "node": {
        "import": "./dist/node/google/index.js",
        "require": "./dist/node/google/index.cjs"
      },
      "default": {
        "import": "./dist/node/google/index.js",
        "require": "./dist/node/google/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src/ --ext .ts",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@robota-sdk/agent-core": "workspace:*"
  }
}
