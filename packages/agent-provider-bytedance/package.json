{
  "name": "@robota-sdk/agent-provider-bytedance",
  "version": "3.0.0-beta.55",
  "description": "ByteDance/BytePlus media integration for Robota SDK - Seedance video generation provider support",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/browser/index.js"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git",
    "directory": "packages/agent-provider-bytedance"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:js": "tsup --no-dts",
    "build:types": "tsup --dts-only",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "scenario:verify": "pnpm --filter @robota-sdk/agent-core build && DRY_RUN=1 pnpm exec tsx examples/example-create-video.ts",
    "scenario:record": "node ../../scripts/harness/record-owner-scenario.mjs --scope packages/agent-provider-bytedance --output examples/scenarios/bytedance-video-dry-run.record.json -- pnpm scenario:verify",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "ai",
    "agent",
    "bytedance",
    "byteplus",
    "seedance",
    "video-generation",
    "robota",
    "typescript"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "peerDependencies": {
    "@robota-sdk/agent-core": "workspace:*"
  },
  "devDependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
