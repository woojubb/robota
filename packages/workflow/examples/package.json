{
  "name": "robota-workflow-examples",
  "private": true,
  "type": "module",
  "description": "Package-owned examples for @robota-sdk/workflow (not part of the workspace)",
  "dependencies": {
    "@robota-sdk/agents": "link:../../agents",
    "@robota-sdk/openai": "link:../../openai",
    "@robota-sdk/team": "link:../../team",
    "@robota-sdk/workflow": "link:.."
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "guarded": "tsx guarded-edge-verification.ts",
    "continued": "tsx continued-conversation-edge-verification.ts",
    "verify": "tsx utils/verify-workflow-connections.ts",
    "scenario": "node utils/scenario-cli.ts",
    "scenario:verify": "node utils/scenario-cli.ts verify",
    "guarded:verify:template": "node utils/scenario-cli.ts verify guarded-edge-verification.ts mandatory-delegation --strategy=hash",
    "continued:verify:template": "node utils/scenario-cli.ts verify continued-conversation-edge-verification.ts continued-conversation --strategy=hash",
    "migrate:fixtures": "node utils/migrate-scenario-fixtures.mjs"
  }
}