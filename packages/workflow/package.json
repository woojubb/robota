{
    "name": "@robota-sdk/workflow",
    "version": "0.1.0",
    "description": "Event-driven workflow visualization system for Robota SDK - real-time workflow building and graph management",
    "type": "module",
    "main": "dist/node/index.js",
    "module": "dist/node/index.mjs",
    "types": "dist/node/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/node/index.d.ts",
            "node": {
                "import": "./dist/node/index.js",
                "require": "./dist/node/index.cjs"
            },
            "browser": {
                "import": "./dist/browser/index.js"
            },
            "default": {
                "import": "./dist/node/index.js",
                "require": "./dist/node/index.cjs"
            }
        },
        "./scenario": {
            "types": "./dist/node/scenario/index.d.ts",
            "node": {
                "import": "./dist/node/scenario/index.js",
                "require": "./dist/node/scenario/index.cjs"
            },
            "default": {
                "import": "./dist/node/scenario/index.js",
                "require": "./dist/node/scenario/index.cjs"
            }
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/woojubb/robota.git",
        "directory": "packages/workflow"
    },
    "homepage": "https://robota.io/",
    "bugs": {
        "url": "https://github.com/woojubb/robota/issues"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rimraf dist",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix"
    },
    "keywords": [
        "workflow",
        "visualization",
        "event-driven",
        "real-time-workflow",
        "ai",
        "agent",
        "llm",
        "typescript",
        "javascript",
        "graph",
        "nodes",
        "edges",
        "workflow-builder",
        "robota",
        "sdk",
        "library"
    ],
    "author": "Robota SDK Team",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@robota-sdk/agents": "workspace:*",
        "@robota-sdk/team": "workspace:*",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^6.18.0",
        "@typescript-eslint/parser": "^6.18.0",
        "@vitest/coverage-v8": "^3.1.3",
        "eslint": "^8.56.0",
        "rimraf": "^5.0.5",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3",
        "vitest": "^1.1.0"
    },
    "publishConfig": {
        "access": "public"
    }
}