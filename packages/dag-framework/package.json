{
  "name": "@robota-sdk/dag-framework",
  "version": "0.1.0-beta.3",
  "private": true,
  "description": "Embeddable in-process DAG runtime — runtime + worker + adapters + default nodes",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "dag",
    "framework",
    "orchestration"
  ],
  "author": "Robota SDK Team",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/dag-adapters-local": "workspace:*",
    "@robota-sdk/dag-api": "workspace:*",
    "@robota-sdk/dag-builder": "workspace:*",
    "@robota-sdk/dag-core": "workspace:*",
    "@robota-sdk/dag-cost": "workspace:*",
    "@robota-sdk/dag-node": "workspace:*",
    "@robota-sdk/dag-orchestration-client": "workspace:*",
    "@robota-sdk/dag-projection": "workspace:*",
    "@robota-sdk/dag-runtime": "workspace:*",
    "@robota-sdk/dag-worker": "workspace:*"
  },
  "optionalDependencies": {
    "@robota-sdk/dag-nodes-default": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsdown": "^0.22.14"
  }
}
