{
  "name": "@robota-sdk/agent-team",
  "version": "3.0.0-beta.20",
  "description": "Multi-agent teamwork functionality for Robota SDK - dynamic agent coordination and task delegation",
  "type": "module",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.mjs",
        "require": "./dist/node/index.js"
      },
      "browser": {
        "import": "./dist/browser/index.js"
      },
      "default": {
        "import": "./dist/node/index.mjs",
        "require": "./dist/node/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git",
    "directory": "packages/agent-team"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:check": "pnpm run typecheck && pnpm run build",
    "dev": "tsup --watch",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "scenario:verify": "pnpm --filter @robota-sdk/agent-core build && pnpm exec tsx examples/verify-offline.ts",
    "scenario:record": "node ../../scripts/harness/record-owner-scenario.mjs --scope packages/team --output examples/scenarios/offline-verify.record.json -- pnpm scenario:verify",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "task-delegation",
    "mcp",
    "tools",
    "typescript",
    "robota",
    "sdk",
    "openai",
    "anthropic",
    "google-ai",
    "ai-integration"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "uuid": "^9.0.1",
    "zod": "^3.24.4",
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-tools": "workspace:*",
    "@robota-sdk/agent-tool-mcp": "workspace:*",
    "@robota-sdk/agent-event-service": "workspace:*"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@types/uuid": "^9.0.7",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1",
    "eslint": "^8.56.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": true
}
