{
  "name": "@robota-sdk/dag-cost",
  "version": "0.1.0",
  "description": "Cost evaluation service for DAG orchestration using CEL formulas",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist/node --clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "dependencies": {
    "@marcbachmann/cel-js": "^7.5.3",
    "@robota-sdk/dag-core": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
