{
  "name": "@robota-sdk/agent-plugin",
  "version": "3.0.0-beta.64",
  "description": "Consolidated plugin implementations for Robota SDK",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "source": "./src/index.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "jssha": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
