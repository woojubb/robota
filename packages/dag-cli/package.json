{
  "name": "@robota-sdk/dag-cli",
  "version": "3.0.0-beta.60",
  "description": "Command-line client for Robota DAG orchestration APIs",
  "type": "module",
  "bin": {
    "robota-dag": "./dist/node/bin.js"
  },
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts --out-dir dist/node --clean && rm -f dist/node/bin.cjs dist/node/bin.d.cts",
    "build:js": "tsup src/index.ts src/bin.ts --format esm,cjs --out-dir dist/node --clean && rm -f dist/node/bin.cjs",
    "build:types": "tsup src/index.ts src/bin.ts --format esm,cjs --dts-only --out-dir dist/node && rm -f dist/node/bin.d.cts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "robota",
    "dag",
    "cli",
    "orchestration"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@robota-sdk/dag-api": "workspace:*",
    "@robota-sdk/dag-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
