{
  "name": "@robota-sdk/agent-cli",
  "version": "3.0.0-beta.10",
  "description": "AI coding assistant CLI built on Robota SDK",
  "type": "module",
  "bin": {
    "robota": "./dist/node/bin.js"
  },
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts --out-dir dist/node --clean",
    "dev": "tsx --env-file=.env src/bin.ts",
    "start": "node --env-file=.env dist/node/bin.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "dependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-sdk": "workspace:*",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^9.1.5",
    "marked-terminal": "^7.3.0",
    "react": "19.2.4",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/react": "^19.2.14",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
