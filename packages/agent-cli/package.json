{
  "name": "@robota-sdk/agent-cli",
  "version": "3.0.0-beta.79",
  "description": "AI coding assistant CLI built on Robota SDK",
  "type": "module",
  "bin": {
    "robota": "./bin/robota.cjs"
  },
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "source": "./src/index.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "pnpm --filter @robota-sdk/agent-web-ui build:spa && node scripts/copy-web-assets.mjs && tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "dev": "tsx src/bin.ts",
    "start": "node dist/node/bin.js",
    "test": "vitest run --passWithNoTests",
    "test:bin": "vitest run --config vitest.bin.config.ts",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rimraf dist",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh",
    "build:bun": "bun scripts/build-bun.mjs",
    "build:bun:all": "bun scripts/build-bun.mjs all",
    "build:bun:darwin-arm64": "bun scripts/build-bun.mjs darwin-arm64",
    "build:bun:darwin-x64": "bun scripts/build-bun.mjs darwin-x64",
    "build:bun:linux-x64": "bun scripts/build-bun.mjs linux-x64",
    "build:bun:linux-arm64": "bun scripts/build-bun.mjs linux-arm64",
    "build:bun:windows-x64": "bun scripts/build-bun.mjs windows-x64",
    "test:bun": "node scripts/e2e-bun-binary.mjs"
  },
  "comment:dependencies": "INFRA-028: agent-cli publishes as a SELF-CONTAINED bundle. ALL @robota-sdk workspace code (incl. the /workflows + dag-* chain) is bundled into dist (see devDependencies + tsdown.config.ts). Runtime `dependencies` therefore contain ONLY the third-party npm packages that the bundled closure imports — kept external so npm installs them from the public registry. Do NOT add any @robota-sdk edge here.",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/genai": "^1.52.0",
    "@marcbachmann/cel-js": "^7.5.3",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "croner": "^10.0.1",
    "fast-glob": "^3.3.3",
    "ink": "^7.0.5",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jssha": "^3.3.1",
    "marked": "^9.1.6",
    "marked-terminal": "^7.3.0",
    "open": "^11.0.0",
    "openai": "^4.104.0",
    "p-limit": "^7.3.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "string-width": "^8.2.1",
    "werift": "^0.23.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@robota-sdk/agent-command": "workspace:*",
    "@robota-sdk/agent-command-workflows": "workspace:*",
    "@robota-sdk/agent-core": "workspace:*",
    "@robota-sdk/agent-remote-pairing": "workspace:*",
    "@robota-sdk/agent-executor": "workspace:*",
    "@robota-sdk/agent-framework": "workspace:*",
    "@robota-sdk/agent-interface-transport": "workspace:*",
    "@robota-sdk/agent-preset": "workspace:*",
    "@robota-sdk/agent-provider-anthropic": "workspace:*",
    "@robota-sdk/agent-provider-defaults": "workspace:*",
    "@robota-sdk/agent-provider-gemini": "workspace:*",
    "@robota-sdk/agent-provider-openai": "workspace:*",
    "@robota-sdk/agent-provider-openai-compatible": "workspace:*",
    "@robota-sdk/agent-provider-replay": "workspace:*",
    "@robota-sdk/agent-session-analytics": "workspace:*",
    "@robota-sdk/agent-subagent-runner": "workspace:*",
    "@robota-sdk/agent-transport": "workspace:*",
    "@robota-sdk/agent-transport-tui": "workspace:*",
    "@robota-sdk/agent-transport-protocol": "workspace:*",
    "@robota-sdk/agent-transport-webrtc": "workspace:*",
    "@robota-sdk/agent-transport-ws": "workspace:*",
    "@types/marked": "^6.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "rimraf": "^5.0.10",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "agent",
    "llm",
    "anthropic",
    "openai",
    "claude",
    "typescript",
    "developer-tools",
    "terminal",
    "automation",
    "multi-provider",
    "robota",
    "open-source"
  ],
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "publishConfig": {
    "access": "public"
  }
}
