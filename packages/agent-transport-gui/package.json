{
  "name": "@robota-sdk/agent-transport-gui",
  "version": "3.0.0-beta.79",
  "description": "GUI presentation layer for a robota session — React components + a wire-protocol session reducer + a desktop shell, rendered over the transport-neutral TServerMessage stream. The GUI analog of agent-transport-tui; consumed by the desktop app (apps/agent-app), the CLI-served monitor (packages/agent-cli-web), and the browser remote surface (agent-transport-webrtc-web + apps/agent-web /remote).",
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "private": true,
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./styles/theme.css": "./src/styles/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "build:js": "tsdown --no-dts",
    "build:types": "tsdown --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@robota-sdk/agent-interface-transport": "workspace:*",
    "@robota-sdk/agent-transport-protocol": "workspace:*",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "rimraf": "^5.0.0",
    "tsdown": "^0.22.14",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
