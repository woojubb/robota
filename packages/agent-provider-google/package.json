{
  "name": "@robota-sdk/agent-provider-google",
  "version": "3.0.0-beta.46",
  "description": "Google AI integration for Robota SDK - Gemini Pro, Gemini Flash, function calling, and tool integration with Google's Generative AI",
  "type": "module",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      },
      "browser": {
        "import": "./dist/browser/index.js"
      },
      "default": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git",
    "directory": "packages/agent-provider-google"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "scenario:verify": "pnpm --filter @robota-sdk/agent-core build && DRY_RUN=1 GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation pnpm exec tsx examples/example-generate-image.ts && DRY_RUN=1 GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation pnpm exec tsx examples/example-compose-image.ts",
    "scenario:record": "node ../../scripts/harness/record-owner-scenario.mjs --scope packages/google --output examples/scenarios/google-image-dry-run.record.json -- pnpm scenario:verify",
    "prepublishOnly": "bash ../../scripts/check-pnpm-publish.sh"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "google",
    "gemini",
    "gemini-pro",
    "gemini-flash",
    "palm",
    "google-ai",
    "function-calling",
    "typescript",
    "javascript",
    "chatbot",
    "conversational-ai",
    "artificial-intelligence",
    "machine-learning",
    "nlp",
    "natural-language-processing",
    "sdk",
    "library",
    "tool-integration",
    "robota",
    "google-api",
    "ai-integration",
    "generative-ai"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.20.0"
  },
  "peerDependencies": {
    "@robota-sdk/agent-core": "workspace:*"
  },
  "devDependencies": {
    "@robota-sdk/agent-core": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
