{
  "name": "robota-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "A simple, powerful TypeScript library for building AI agents with function calling, tool integration, and multi-provider support for OpenAI, Anthropic, and Google AI",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/woojubb/robota.git"
  },
  "homepage": "https://robota.io/",
  "bugs": {
    "url": "https://github.com/woojubb/robota/issues"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build:js && node scripts/build-types-ordered.mjs",
    "build:all": "pnpm run build && pnpm run docs:build",
    "build:deps": "pnpm run build",
    "test": "pnpm run -r --if-present test",
    "typecheck": "pnpm run -r --if-present typecheck",
    "lint": "eslint packages apps --ext .ts,.tsx --cache",
    "lint:fix": "eslint packages apps --ext .ts,.tsx --cache --fix",
    "dev": "pnpm run -r --if-present dev",
    "clean": "pnpm run -r --if-present clean",
    "clean:js": "find ./src -type f \\( -name \"*.js\" -o -name \"*.js.map\" -o -name \"*.d.ts\" -o -name \"*.d.ts.map\" \\) -not -path \"*/node_modules/*\" -delete",
    "prepare": "husky install",
    "docs:dev": "pnpm --filter robota-docs run dev",
    "docs:build": "node scripts/docs/prepare-docs.js",
    "docs:preview": "pnpm --filter robota-docs run preview",
    "docs:deploy": "pnpm docs:build && node scripts/docs/deploy-gh-pages.mjs",
    "docs:validate-structure": "node scripts/docs/validate-package-docs-structure.mjs",
    "dag:dev": "pnpm --filter @robota-sdk/dag-designer --filter @robota-sdk/dag-runtime-server --filter @robota-sdk/dag-orchestrator-server --filter @robota-sdk/dag-studio -r --parallel dev",
    "dag:build": "pnpm --filter @robota-sdk/dag-core build && pnpm --filter @robota-sdk/dag-api build && pnpm --filter @robota-sdk/dag-orchestrator build && pnpm --filter @robota-sdk/dag-designer build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "cli:dev": "tsx --env-file=packages/agent-cli/.env packages/agent-cli/src/bin.ts",
    "web:dev": "pnpm --filter @robota-sdk/agent-web run dev",
    "web:build": "pnpm --filter @robota-sdk/agent-web run build",
    "web:start": "pnpm --filter @robota-sdk/agent-web run start",
    "readme:copy": "node scripts/docs/copy-readme.cjs copy",
    "readme:cleanup": "node scripts/docs/copy-readme.cjs cleanup",
    "readme:validate": "node scripts/docs/validate-readmes.js",
    "harness:scan": "pnpm harness:scan:consistency && pnpm harness:scan:specs && pnpm harness:scan:deps && pnpm harness:scan:publish && pnpm harness:scan:test-plans && pnpm harness:scan:file-size && pnpm harness:scan:dist && pnpm docs:validate-structure",
    "harness:scan:publish": "node scripts/harness/check-publish-safety.mjs",
    "harness:scan:deps": "node scripts/harness/check-dependency-direction.mjs",
    "harness:scan:consistency": "node scripts/harness/scan-consistency.mjs",
    "harness:scan:specs": "node scripts/harness/audit-spec-coverage.mjs",
    "harness:scan:test-plans": "node scripts/harness/scan-test-plan.mjs",
    "harness:scan:file-size": "node scripts/harness/scan-file-size.mjs",
    "harness:scan:dist": "node scripts/harness/scan-dist-freshness.mjs",
    "harness:verify": "node scripts/harness/verify-change.mjs",
    "harness:record": "node scripts/harness/record-change.mjs",
    "harness:review": "node scripts/harness/review-change.mjs",
    "harness:self-check": "node scripts/harness/self-check.mjs",
    "harness:cleanup": "node scripts/harness/cleanup-drift.mjs",
    "harness:bootstrap": "node scripts/harness/bootstrap.mjs",
    "harness:run-context": "node scripts/harness/collect-run-context.mjs",
    "git:push-tags": "git push --tags",
    "pre-publish:check": "bash scripts/pre-publish-docs-check.sh",
    "publish:packages": "bash scripts/publish/publish-packages.sh",
    "publish:beta": "bash scripts/publish/publish-packages.sh",
    "ci:publish": "pnpm publish -r",
    "knip": "knip",
    "deps:check": "depcruise packages/ apps/ --config .dependency-cruiser.cjs"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "function-calling",
    "typescript",
    "javascript",
    "openai",
    "anthropic",
    "google-ai",
    "claude",
    "gpt",
    "gemini",
    "chatbot",
    "conversational-ai",
    "artificial-intelligence",
    "machine-learning",
    "nlp",
    "natural-language-processing",
    "sdk",
    "library",
    "tool-integration",
    "multi-provider",
    "robota"
  ],
  "author": "Robota SDK Team",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^8.56.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "glob": "^10.5.0",
    "husky": "^8.0.3",
    "knip": "^5.86.0",
    "lint-staged": "^15.2.0",
    "marked": "^9.1.5",
    "prettier": "^3.1.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.25.9",
    "typedoc-plugin-markdown": "^3.17.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": "8.15.4"
  },
  "packageManager": "pnpm@8.15.4",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.4"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=4.5.5",
      "node-forge": ">=1.4.0",
      "protobufjs": ">=7.5.5",
      "jws@^3.0.0": "^3.2.3",
      "jws@^4.0.0": "^4.0.1",
      "tar": ">=7.5.13",
      "handlebars": ">=4.7.9",
      "rollup": "~4.59.1",
      "flatted": ">=3.4.2",
      "preact": ">=10.26.10",
      "minimatch@^3.0.0": "^3.1.5",
      "minimatch@^9.0.0": "^9.0.9",
      "picomatch@^2.0.0": "^2.3.2",
      "picomatch@^4.0.0": "^4.0.4",
      "next": "^15.5.15",
      "express@^4>path-to-regexp": "^0.1.13",
      "router>path-to-regexp": "^8.4.2",
      "defu": ">=6.1.5",
      "vite@^7": ">=7.3.2",
      "lodash": ">=4.18.0"
    }
  },
  "workspaces": [
    "packages/*",
    "packages/dag-nodes/*",
    "packages/dag-*",
    "apps/*"
  ],
  "volta": {
    "node": "22.14.0"
  }
}
